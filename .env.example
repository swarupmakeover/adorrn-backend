# ─────────────────────────────────────────────
# Local Development (Docker Postgres)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://adorrn:adorrn_dev@localhost:5432/adorrn_herbal

# ─────────────────────────────────────────────
# Production / Neon
# ─────────────────────────────────────────────
# DATABASE_URL=postgresql://user:pass@your-neon-host/dbname?sslmode=require

# ─────────────────────────────────────────────
# Clerk (use test/sandbox keys from clerk.com)
# ─────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────
# Cloudinary (free tier / demo cloud)
# ─────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud
CLOUDINARY_API_KEY=your_key
CLOUDINARY_API_SECRET=your_secret

# ─────────────────────────────────────────────
# Razorpay (use test mode keys)
# ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_test_secret
RAZORPAY_WEBHOOK_SECRET=whsec_test_xxxxxxxx

# ─────────────────────────────────────────────
# App
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
INTERNAL_WEBHOOK_SECRET=dev_webhook_secret_change_in_prod
REVALIDATION_TOKEN=dev_revalidation_token
PORT=3001
NODE_ENV=development
